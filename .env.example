# ============================================================
# Flood Early Warning System — Environment Variables Template
# Copy this file to .env and fill in your values.
# ============================================================

# --- Elastic Stack ---
ELASTIC_PASSWORD=changeme
KIBANA_PASSWORD=changeme

# --- MongoDB ---
MONGO_USERNAME=admin
MONGO_PASSWORD=changeme
MONGO_URI=mongodb://admin:changeme@localhost:27017/flood_warning?authSource=admin

# --- Weather APIs ---
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
WEATHER_GOV_BASE_URL=https://api.weather.gov

# --- FastAPI Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your_super_secret_key_here

# --- Next.js Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
# OR use Leaflet (no token required)
NEXT_PUBLIC_MAP_PROVIDER=leaflet

# --- Elasticsearch ---
ES_HOST=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=changeme

# --- Feature Flags ---
ENABLE_ML_PREDICTIONS=false
ENABLE_REAL_TIME_INGESTION=false

# --- AWS (for deployment; never commit real keys) ---
# Used when deploying to EC2/ECS/Lambda or when backend uses S3/Kinesis etc.
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-southeast-1
