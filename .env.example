# ============================================================
# Flood Early Warning System — Environment Variables Template
# Copy this file to .env and fill in your values.
# ============================================================

# --- Elastic Stack ---
ELASTIC_PASSWORD=changeme
KIBANA_PASSWORD=changeme

# --- MongoDB ---
MONGO_USERNAME=admin
MONGO_PASSWORD=changeme
MONGO_URI=mongodb://admin:changeme@localhost:27017/flood_warning?authSource=admin

# --- Weather APIs ---
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
WEATHER_GOV_BASE_URL=https://api.weather.gov

# --- FastAPI Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your_super_secret_key_here

# --- Next.js Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
# OR use Leaflet (no token required)
NEXT_PUBLIC_MAP_PROVIDER=leaflet

# --- Elasticsearch ---
ES_HOST=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=changeme

# --- Feature Flags ---
ENABLE_ML_PREDICTIONS=false
ENABLE_REAL_TIME_INGESTION=false

# --- Assistant (Claude: Amazon Bedrock or Anthropic) ---
# Provider: bedrock (default) uses AWS keys below; anthropic uses ANTHROPIC_API_KEY.
ASSISTANT_PROVIDER=bedrock
# Bedrock model ID; enable the model in AWS Console → Bedrock → Model access for your region.
ASSISTANT_BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# For Bedrock: use your AWS Access Key ID and Secret Access Key.
# For Anthropic only: set ANTHROPIC_API_KEY and ASSISTANT_PROVIDER=anthropic.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- AWS (Bedrock assistant + deployment; never commit real keys) ---
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
